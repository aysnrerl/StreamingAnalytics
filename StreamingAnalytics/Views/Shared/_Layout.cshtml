<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — StreamingAnalytics</title>
    <!-- Premium Google Fonts: Plus Jakarta Sans & Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* ── Modern Reset & Variables ── */
        :root {
            --bg-body: #060813;
            --bg-card: #0b0e22;
            --bg-sidebar: #090b1a;
            --border-glow: rgba(99, 102, 241, 0.09);
            --border-glow-hover: rgba(139, 92, 246, 0.25);
            --color-text-main: #f1f5f9;
            --color-text-muted: #64748b;
            --color-text-dark: #475569;
            
            /* Neon Accents */
            --accent-primary: #6366f1;   /* Indigo */
            --accent-secondary: #8b5cf6; /* Violet */
            --accent-cyan: #06b6d4;      /* Cyan */
            --accent-emerald: #10b981;   /* Emerald */
            --accent-amber: #f59e0b;     /* Amber */
            --accent-rose: #f43f5e;      /* Rose */
            
            --gradient-neon: linear-gradient(135deg, #6366f1 0%, #a78bfa 50%, #f43f5e 100%);
            --gradient-active: linear-gradient(90deg, rgba(99, 102, 241, 0.12) 0%, rgba(139, 92, 246, 0.02) 100%);
            --shadow-neon: 0 0 20px rgba(99, 102, 241, 0.15);
        }

        *, *::before, *::after { 
            box-sizing: border-box; 
            margin: 0; 
            padding: 0; 
        }

        body {
            font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
            background: var(--bg-body);
            background-image: 
                radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.1) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.05) 0px, transparent 50%),
                radial-gradient(at 50% 0%, rgba(6, 182, 212, 0.05) 0px, transparent 50%);
            color: var(--color-text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            letter-spacing: -0.2px;
        }

        /* Custom Modern Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-body);
        }
        ::-webkit-scrollbar-thumb {
            background: #161b33;
            border-radius: 99px;
            border: 2px solid var(--bg-body);
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--accent-primary);
        }

        /* ── Sidebar ── */
        .sidebar {
            width: 260px;
            min-height: 100vh;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-glow);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; 
            left: 0;
            z-index: 100;
            box-shadow: 10px 0 30px rgba(0, 0, 0, 0.25);
        }

        .sidebar-logo {
            padding: 26px 24px 20px;
            border-bottom: 1px solid var(--border-glow);
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .sidebar-logo span {
            font-size: 1.2rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            background: var(--gradient-neon);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .sidebar-logo small {
            display: block;
            color: var(--color-text-muted);
            font-size: .72rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .sidebar-section {
            padding: 20px 24px 8px;
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--color-text-dark);
        }

        .sidebar-nav { 
            flex: 1; 
            padding: 8px 12px; 
            overflow-y: auto;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 16px;
            color: #94a3b8;
            text-decoration: none;
            font-size: .88rem;
            font-weight: 600;
            border-radius: 10px;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            margin-bottom: 4px;
            border-left: 3px solid transparent;
        }

        .nav-link:hover {
            color: var(--color-text-main);
            background: rgba(255, 255, 255, 0.03);
            transform: translateX(4px);
        }

        .nav-link.active {
            color: var(--color-text-main);
            background: var(--gradient-active);
            border-left-color: var(--accent-primary);
            box-shadow: inset 0 0 12px rgba(99, 102, 241, 0.05);
            text-shadow: 0 0 10px rgba(99, 102, 241, 0.4);
        }

        .nav-link.active .icon {
            filter: drop-shadow(0 0 5px rgba(99, 102, 241, 0.8));
        }

        .nav-link .icon { 
            font-size: 1.05rem; 
            width: 20px; 
            text-align: center; 
            transition: transform 0.2s;
        }

        .nav-link:hover .icon {
            transform: scale(1.15);
        }

        .sidebar-footer {
            padding: 20px 24px;
            border-top: 1px solid var(--border-glow);
            font-size: .75rem;
            font-weight: 500;
            color: var(--color-text-dark);
            text-align: center;
        }

        /* ── Main Content Area ── */
        .main-content {
            margin-left: 260px;
            flex: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        /* ── Vibrant Glowing Top Bar ── */
        .topbar {
            height: 70px;
            background: rgba(9, 11, 26, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border-glow);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            position: sticky;
            top: 0;
            z-index: 99;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        }

        .topbar-title {
            font-size: .95rem;
            font-weight: 700;
            color: var(--color-text-muted);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .topbar-title span {
            color: var(--color-text-main);
            font-weight: 800;
        }

        .topbar-badge {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.2) 0%, rgba(167, 139, 250, 0.2) 100%);
            border: 1px solid rgba(167, 139, 250, 0.3);
            color: #c084fc;
            border-radius: 99px;
            padding: 5px 14px;
            font-size: .75rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            box-shadow: 0 0 15px rgba(167, 139, 250, 0.15);
            animation: pulse-glow 2s infinite;
        }

        @@keyframes pulse-glow {
            0% { box-shadow: 0 0 10px rgba(167, 139, 250, 0.1); }
            50% { box-shadow: 0 0 20px rgba(167, 139, 250, 0.25); border-color: rgba(167, 139, 250, 0.5); }
            100% { box-shadow: 0 0 10px rgba(167, 139, 250, 0.1); }
        }

        /* ── Page Transition ── */
        .page-body {
            padding: 32px;
            flex: 1;
            animation: fadeIn 0.4s ease-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Responsive Design */
        @@media (max-width: 1024px) {
            .sidebar {
                width: 70px;
            }
            .sidebar-logo span, .sidebar-logo small, .sidebar-section, .nav-link span:not(.icon), .sidebar-footer {
                display: none;
            }
            .sidebar-logo {
                padding: 20px 0;
                align-items: center;
            }
            .sidebar-logo::before {
                content: "🎬";
                font-size: 1.4rem;
            }
            .nav-link {
                justify-content: center;
                padding: 12px;
                border-left: none;
            }
            .nav-link.active {
                background: rgba(99, 102, 241, 0.2);
                border-radius: 8px;
            }
            .main-content {
                margin-left: 70px;
            }
        }
    </style>
</head>
<body>

    <!-- ══ STUNNING GLOWING SIDEBAR ══════════════════════════════════════ -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <span>🎬 StreamPulse</span>
            <small>Data Engine v1.2</small>
        </div>

        <nav class="sidebar-nav">
            <div class="sidebar-section">Ana Menü</div>

            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
               href="/Dashboard">
                <span class="icon">📊</span> <span>Dashboard</span>
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Streaming" ? "active" : "")"
               href="/Streaming">
                <span class="icon">🗂️</span> <span>Tüm Kayıtlar</span>
            </a>

            <div class="sidebar-section">İstatistikler</div>

            <a class="nav-link @(ViewBag.ActiveSection == "monthly" ? "active" : "")"
               href="/Dashboard/Charts?section=monthly">
                <span class="icon">📈</span> <span>Aylık Trend (S5)</span>
            </a>

            <a class="nav-link @(ViewBag.ActiveSection == "platform" ? "active" : "")"
               href="/Dashboard/Charts?section=platform">
                <span class="icon">🎯</span> <span>Platform Dağılımı (S6)</span>
            </a>

            <a class="nav-link @(ViewBag.ActiveSection == "genre" ? "active" : "")"
               href="/Dashboard/Charts?section=genre">
                <span class="icon">🎭</span> <span>Tür Dağılımı (S7)</span>
            </a>

            <a class="nav-link @(ViewBag.ActiveSection == "device" ? "active" : "")"
               href="/Dashboard/Charts?section=device">
                <span class="icon">📱</span> <span>Cihaz Dağılımı (S8)</span>
            </a>

            <a class="nav-link @(ViewBag.ActiveSection == "country" ? "active" : "")"
               href="/Dashboard/Charts?section=country">
                <span class="icon">🌍</span> <span>Ülke Analizi (S9)</span>
            </a>

            <a class="nav-link @(ViewBag.ActiveSection == "hourly" ? "active" : "")"
               href="/Dashboard/Charts?section=hourly">
                <span class="icon">⚡</span> <span>Saatlik İzlenme (S10)</span>
            </a>

            <div class="sidebar-section">Listeler</div>

            <a class="nav-link @(ViewBag.ActiveSection == "top10" ? "active" : "")"
               href="/Dashboard/Charts?section=top10">
                <span class="icon">🏆</span> <span>En Çok İzlenen (S11)</span>
            </a>

            <a class="nav-link @(ViewBag.ActiveSection == "recent" ? "active" : "")"
               href="/Dashboard/Charts?section=recent">
                <span class="icon">🕐</span> <span>Son İzlemeler (S12)</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            © 2026 StreamPulse
        </div>
    </aside>

    <!-- ══ MAIN DYNAMIC CONTENT AREA ══════════════════════════════════════ -->
    <div class="main-content">
        <header class="topbar">
            <div class="topbar-title">
                StreamPulse / <span>@ViewData["Title"]</span>
            </div>
            <span class="topbar-badge">⚡ 1.000.000 Canlı Kayıt</span>
        </header>

        <main class="page-body">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
