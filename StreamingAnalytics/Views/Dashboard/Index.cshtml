@model StreamingAnalytics.Dtos.DashboardViewModel
@{
    ViewData["Title"] = "Genel Bakış";
}

<div class="home-wrap">

    <!-- ── Header ─────────────────────────────────────────── -->
    <div class="welcome-row">
        <div>
            <h1 class="page-h1">Performans Dashboard</h1>
            <p class="page-sub">StreamPulse canlı veri analitiği motoru • Gerçek zamanlı sorgu paneli</p>
        </div>
        <a href="/Streaming" class="cta-btn">🗂️ Tüm Kayıtları Gör</a>
    </div>

    <!-- ── 4 Premium Metrics Cards (Queries 1-4) ──────────────── -->
    <div class="kart-grid">

        <div class="kart" style="--accent: var(--accent-primary); --glow: rgba(99, 102, 241, 0.2);">
            <div class="kart-glow"></div>
            <div class="kart-content">
                <div class="kart-header">
                    <span class="kart-icon">▶️</span>
                    <span class="kart-badge">Sorgu 1</span>
                </div>
                <div class="kart-body">
                    <p class="kart-label">Toplam İzlenme</p>
                    <h2 class="kart-val">@Model.Stats.TotalWatchCount.ToString("N0")</h2>
                </div>
            </div>
        </div>

        <div class="kart" style="--accent: var(--accent-emerald); --glow: rgba(16, 185, 129, 0.2);">
            <div class="kart-glow"></div>
            <div class="kart-content">
                <div class="kart-header">
                    <span class="kart-icon">👥</span>
                    <span class="kart-badge">Sorgu 2</span>
                </div>
                <div class="kart-body">
                    <p class="kart-label">Tekil İzleyici</p>
                    <h2 class="kart-val">@Model.Stats.TotalUniqueUsers.ToString("N0")</h2>
                </div>
            </div>
        </div>

        <div class="kart" style="--accent: var(--accent-amber); --glow: rgba(245, 158, 11, 0.2);">
            <div class="kart-glow"></div>
            <div class="kart-content">
                <div class="kart-header">
                    <span class="kart-icon">⏱️</span>
                    <span class="kart-badge">Sorgu 3</span>
                </div>
                <div class="kart-body">
                    <p class="kart-label">İzlenme Saati</p>
                    <h2 class="kart-val">@Model.Stats.TotalWatchHours.ToString("N0")</h2>
                </div>
            </div>
        </div>

        <div class="kart" style="--accent: var(--accent-rose); --glow: rgba(244, 63, 94, 0.2);">
            <div class="kart-glow"></div>
            <div class="kart-content">
                <div class="kart-header">
                    <span class="kart-icon">⭐</span>
                    <span class="kart-badge">Sorgu 4</span>
                </div>
                <div class="kart-body">
                    <p class="kart-label">Ortalama Puan</p>
                    <h2 class="kart-val">@Model.Stats.AverageRating.ToString("F1") <small>/ 10</small></h2>
                </div>
            </div>
        </div>

    </div>

    <!-- ── 8 Analytical Navigation Tiles (Queries 5-12) ──────── -->
    <h2 class="section-title">📊 Analitik Raporlama Panelleri</h2>
    <div class="quick-grid">

        <a href="/Dashboard/Charts?section=monthly" class="quick-card" style="--border-hover: var(--accent-primary);">
            <div class="qc-glow"></div>
            <div class="qc-icon-wrap" style="--bg: rgba(99, 102, 241, 0.15); --color: var(--accent-primary);">📈</div>
            <div class="qc-body">
                <div class="qc-meta">Sorgu 5</div>
                <strong>Aylık İzlenme Trendi</strong>
                <p>Zaman serisi izlenme analizi</p>
            </div>
            <div class="qc-arr">→</div>
        </a>

        <a href="/Dashboard/Charts?section=platform" class="quick-card" style="--border-hover: var(--accent-cyan);">
            <div class="qc-glow"></div>
            <div class="qc-icon-wrap" style="--bg: rgba(6, 182, 212, 0.15); --color: var(--accent-cyan);">🎯</div>
            <div class="qc-body">
                <div class="qc-meta">Sorgu 6</div>
                <strong>Platform Dağılımı</strong>
                <p>Platform pazar payı oranları</p>
            </div>
            <div class="qc-arr">→</div>
        </a>

        <a href="/Dashboard/Charts?section=genre" class="quick-card" style="--border-hover: var(--accent-secondary);">
            <div class="qc-glow"></div>
            <div class="qc-icon-wrap" style="--bg: rgba(139, 92, 246, 0.15); --color: var(--accent-secondary);">🎭</div>
            <div class="qc-body">
                <div class="qc-meta">Sorgu 7</div>
                <strong>Tür Dağılımı</strong>
                <p>İzleyici kategorik eğilimleri</p>
            </div>
            <div class="qc-arr">→</div>
        </a>

        <a href="/Dashboard/Charts?section=device" class="quick-card" style="--border-hover: var(--accent-amber);">
            <div class="qc-glow"></div>
            <div class="qc-icon-wrap" style="--bg: rgba(245, 158, 11, 0.15); --color: var(--accent-amber);">📱</div>
            <div class="qc-body">
                <div class="qc-meta">Sorgu 8</div>
                <strong>Cihaz Dağılımı</strong>
                <p>Kullanılan donanım istatistikleri</p>
            </div>
            <div class="qc-arr">→</div>
        </a>

        <a href="/Dashboard/Charts?section=country" class="quick-card" style="--border-hover: var(--accent-emerald);">
            <div class="qc-glow"></div>
            <div class="qc-icon-wrap" style="--bg: rgba(16, 185, 129, 0.15); --color: var(--accent-emerald);">🌍</div>
            <div class="qc-body">
                <div class="qc-meta">Sorgu 9</div>
                <strong>Ülke Dağılımı</strong>
                <p>Coğrafi izlenme yoğunlukları</p>
            </div>
            <div class="qc-arr">→</div>
        </a>

        <a href="/Dashboard/Charts?section=hourly" class="quick-card" style="--border-hover: rgba(244, 63, 94, 0.8);">
            <div class="qc-glow"></div>
            <div class="qc-icon-wrap" style="--bg: rgba(244, 63, 94, 0.15); --color: var(--accent-rose);">⚡</div>
            <div class="qc-body">
                <div class="qc-meta">Sorgu 10</div>
                <strong>Saatlik İzlenme Trendi</strong>
                <p>Günün yoğun saatleri analizi</p>
            </div>
            <div class="qc-arr">→</div>
        </a>

        <a href="/Dashboard/Charts?section=top10" class="quick-card" style="--border-hover: #e0f2fe;">
            <div class="qc-glow"></div>
            <div class="qc-icon-wrap" style="--bg: rgba(255, 255, 255, 0.08); --color: #e2e8f0;">🏆</div>
            <div class="qc-body">
                <div class="qc-meta">Sorgu 11</div>
                <strong>En Çok İzlenenler</strong>
                <p>Popüler içerik sıralaması</p>
            </div>
            <div class="qc-arr">→</div>
        </a>

        <a href="/Dashboard/Charts?section=recent" class="quick-card" style="--border-hover: rgba(99, 102, 241, 0.5);">
            <div class="qc-glow"></div>
            <div class="qc-icon-wrap" style="--bg: rgba(99, 102, 241, 0.1); --color: #a78bfa;">🕐</div>
            <div class="qc-body">
                <div class="qc-meta">Sorgu 12</div>
                <strong>Son İzleme Kayıtları</strong>
                <p>En son tetiklenen 10 log</p>
            </div>
            <div class="qc-arr">→</div>
        </a>

    </div>

</div>

<style>
    .home-wrap { max-width: 1200px; margin: 0 auto; }

    /* ── Header ── */
    .welcome-row { 
        display: flex; 
        align-items: center; 
        justify-content: space-between; 
        margin-bottom: 32px; 
    }
    .page-h1 { 
        font-size: 1.8rem; 
        font-weight: 800; 
        letter-spacing: -0.8px; 
        color: #fff; 
        background: linear-gradient(135deg, #fff 30%, #94a3b8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .page-sub { 
        font-size: .88rem; 
        color: var(--color-text-muted); 
        margin-top: 6px; 
        font-weight: 500;
    }
    .cta-btn { 
        background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%); 
        color: white; 
        border-radius: 12px; 
        padding: 12px 24px; 
        text-decoration: none; 
        font-weight: 700; 
        font-size: .88rem; 
        letter-spacing: -0.2px;
        transition: all .25s ease; 
        box-shadow: 0 4px 15px rgba(99,102,241,0.25);
        border: 1px solid rgba(255,255,255,0.05);
    }
    .cta-btn:hover { 
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(99,102,241,0.4);
        opacity: 0.95;
    }

    /* ── 4 Premium Cards ── */
    .kart-grid { 
        display: grid; 
        grid-template-columns: repeat(4, 1fr); 
        gap: 20px; 
        margin-bottom: 40px; 
    }
    .kart { 
        background: rgba(11, 14, 34, 0.6); 
        border-radius: 18px; 
        position: relative;
        overflow: hidden; 
        border: 1px solid rgba(255, 255, 255, 0.03); 
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
        cursor: default; 
    }
    .kart::before {
        content: "";
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: var(--accent);
    }
    .kart-glow {
        position: absolute;
        width: 120px;
        height: 120px;
        background: var(--glow);
        filter: blur(40px);
        border-radius: 99px;
        top: -60px;
        right: -60px;
        transition: all 0.3s ease;
    }
    .kart-content {
        padding: 24px;
        position: relative;
        z-index: 2;
    }
    .kart-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }
    .kart-icon {
        font-size: 1.5rem;
    }
    .kart-badge {
        font-size: .65rem;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: var(--color-text-muted);
        padding: 3px 8px;
        border-radius: 99px;
        letter-spacing: 0.5px;
    }
    .kart-label {
        font-size: .78rem;
        color: var(--color-text-muted);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 6px;
    }
    .kart-val {
        font-size: 1.7rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        text-shadow: 0 2px 10px rgba(0,0,0,0.2);
    }
    .kart-val small {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        font-weight: 500;
    }

    /* Hover States for Cards */
    .kart:hover { 
        transform: translateY(-5px); 
        border-color: rgba(255,255,255,0.08);
        box-shadow: 0 12px 30px rgba(0,0,0,0.3), 0 0 15px var(--glow);
    }
    .kart:hover .kart-glow {
        transform: scale(1.3);
    }

    /* ── Section Title ── */
    .section-title { 
        font-size: 1.05rem; 
        font-weight: 700; 
        color: #94a3b8; 
        margin-bottom: 20px; 
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .section-title::after {
        content: "";
        height: 1px;
        flex: 1;
        background: linear-gradient(90deg, rgba(148, 163, 184, 0.15) 0%, transparent 100%);
    }

    /* ── 8 Navigation Tiles Grid ── */
    .quick-grid { 
        display: grid; 
        grid-template-columns: repeat(4, 1fr); 
        gap: 16px; 
    }
    .quick-card { 
        background: rgba(11, 14, 34, 0.5); 
        border: 1px solid rgba(255, 255, 255, 0.02); 
        border-radius: 16px; 
        padding: 20px; 
        display: flex; 
        flex-direction: column;
        position: relative;
        text-decoration: none; 
        color: inherit; 
        overflow: hidden;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); 
    }
    .qc-glow {
        position: absolute;
        width: 100px;
        height: 100px;
        background: radial-gradient(circle, rgba(255,255,255,0.02) 0%, transparent 70%);
        top: -50px; left: -50px;
        transition: all 0.3s ease;
    }
    .qc-icon-wrap {
        font-size: 1.4rem;
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: var(--bg);
        color: var(--color);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
        border: 1px solid rgba(255, 255, 255, 0.03);
        box-shadow: inset 0 2px 5px rgba(255,255,255,0.05);
        transition: all 0.25s ease;
    }
    .qc-body { 
        flex: 1; 
    }
    .qc-meta {
        font-size: .65rem;
        font-weight: 700;
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
    }
    .qc-body strong { 
        font-size: .95rem; 
        color: #e2e8f0; 
        font-weight: 700; 
        display: block; 
        margin-bottom: 4px; 
        transition: color 0.2s;
    }
    .qc-body p { 
        font-size: .78rem; 
        color: var(--color-text-muted); 
        line-height: 1.4;
        margin: 0; 
    }
    .qc-arr { 
        position: absolute;
        right: 20px;
        top: 20px;
        color: #1e293b; 
        font-size: 1.1rem; 
        font-weight: 700;
        transition: all 0.25s ease; 
    }

    /* Hover States for Tiles */
    .quick-card:hover { 
        background: rgba(16, 20, 48, 0.7); 
        border-color: var(--border-hover); 
        transform: translateY(-4px); 
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3), 0 0 12px rgba(99, 102, 241, 0.05);
    }
    .quick-card:hover .qc-icon-wrap {
        transform: scale(1.1);
        box-shadow: 0 0 12px var(--color);
    }
    .quick-card:hover .qc-body strong {
        color: #fff;
    }
    .quick-card:hover .qc-arr { 
        color: var(--border-hover); 
        transform: translateX(4px);
    }

    /* Responsive adjustments */
    @@media (max-width: 1200px) {
        .quick-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 900px) {
        .kart-grid { grid-template-columns: repeat(2, 1fr); }
        .quick-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @@media (max-width: 600px) {
        .kart-grid { grid-template-columns: 1fr; }
        .quick-grid { grid-template-columns: 1fr; }
        .welcome-row { flex-direction: column; align-items: flex-start; gap: 16px; }
    }
</style>
